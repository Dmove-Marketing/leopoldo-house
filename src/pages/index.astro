---
// Gerado a partir de: index.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import LeadForm from '../components/forms/LeadForm.astro';
import Img from '../components/ui/Img.astro';
import '../styles/index.css';
---

<Base
  title="Leopoldo House — Eventos Corporativos no Itaim Bibi"
  description="Espaço para eventos corporativos no Itaim Bibi, São Paulo. Sofisticação, estrutura e alta gastronomia para fortalecer relacionamentos e valorizar sua marca."
  ogImage="/images/og-index.jpg"
>
<!-- ════════════ NAV ════════════ -->
<!-- ════════════ HERO ════════════ -->
<section class="hero" id="top">
  <Img src="hero.png" alt="Salão do Leopoldo House em evento corporativo" priority width={1920} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1" />
  <div class="hero-overlay"></div>
  <div class="hero-inner wrap">
    <Img src="logo-leopoldo.png" alt="Leopoldo House" class="hero-logo" width={280} priority />
    <h1 class="display">Faça seu evento corporativo<br>em um espaço que comunica<br>o valor da sua marca.</h1>
    <p class="lede">Espaço para eventos no Itaim Bibi, São Paulo.</p>
    <div class="actions">
      <a href="#contato" class="btn btn-primary">Solicite um orçamento <span class="arr">→</span></a>
    </div>
  </div>
</section>

<!-- ════════════ SOBRE ════════════ -->
<section class="about" id="sobre">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow center">O Espaço</span>
      <h2 class="h2">O espaço que se adapta às suas ideias.</h2>
      <p class="lede">Localizado no Itaim Bibi, um dos endereços mais valorizados de São Paulo, o Leopoldo House reúne sofisticação, estrutura e alta gastronomia para empresas que buscam fortalecer relacionamentos e valorizar sua imagem, proporcionando uma experiência premium para colaboradores, parceiros e clientes.</p>
    </div>
    <div class="about-carousel reveal" data-carousel>
      <div class="about-track-wrap">
        <div class="about-track">
          <div class="about-slide"><Img src="sobre-01.png" alt="Leopoldo House — vista do salão decorado" width={800} /></div>
          <div class="about-slide"><Img src="sobre-02.jpg" alt="Leopoldo House — ambiente em evento" width={800} /></div>
          <div class="about-slide"><Img src="sobre-03.jpg" alt="Leopoldo House — detalhe do espaço" width={800} /></div>
          <div class="about-slide"><Img src="sobre-04.jpg" alt="Leopoldo House — iluminação do evento" width={800} /></div>
          <div class="about-slide"><Img src="sobre-05.jpg" alt="Leopoldo House — mesas decoradas" width={800} /></div>
          <div class="about-slide"><Img src="sobre-06.jpg" alt="Leopoldo House — lounge" width={800} /></div>
          <div class="about-slide"><Img src="sobre-07.jpg" alt="Leopoldo House — área de convivência" width={800} /></div>
          <div class="about-slide"><Img src="sobre-08.jpg" alt="Leopoldo House — espaço configurado" width={800} /></div>
          <div class="about-slide"><Img src="sobre-09.jpg" alt="Leopoldo House — visão geral" width={800} /></div>
        </div>
      </div>

      <button class="carousel-btn carousel-prev" aria-label="Anterior">&#8592;</button>
      <button class="carousel-btn carousel-next" aria-label="Próxima">&#8594;</button>

      <div class="carousel-dots" data-dots></div>
    </div>
  </div>
</section>

<!-- ════════════ TIPOS DE EVENTO ════════════ -->
<section class="events" id="eventos">
  <div class="wrap">
    <div class="section-head light reveal">
      <span class="eyebrow center light">Versatilidade</span>
      <h2 class="h2">Diversas possibilidades. O mesmo padrão de excelência.</h2>
      <p class="lede">Com pé-direito de 7 metros e 450m² de área total, o Leopoldo House se destaca pela versatilidade do seu layout, que se adapta a diferentes formatos de eventos. O espaço acomoda até 230 convidados em coquetel, 250 em jantar e 130 em plenária.</p>
    </div>

    <div class="type-list reveal">
      <div class="type-row"><span class="idx">01</span><span class="nm">Coquetéis</span><span class="ar">→</span></div>
      <div class="type-row"><span class="idx">02</span><span class="nm">Plenárias</span><span class="ar">→</span></div>
      <div class="type-row"><span class="idx">03</span><span class="nm">Workshops</span><span class="ar">→</span></div>
      <div class="type-row"><span class="idx">04</span><span class="nm">Convenções</span><span class="ar">→</span></div>
      <div class="type-row"><span class="idx">05</span><span class="nm">Treinamentos</span><span class="ar">→</span></div>
      <div class="type-row"><span class="idx">06</span><span class="nm">Jantares</span><span class="ar">→</span></div>
      <div class="type-row"><span class="idx">07</span><span class="nm">Confraternizações</span><span class="ar">→</span></div>
    </div>
  </div>
</section>

<!-- ════════════ ESTRUTURA ════════════ -->
<section class="structure" id="estrutura">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow center">Estrutura</span>
      <h2 class="h2">Uma estrutura que impressiona já no primeiro contato.</h2>
      <p class="lede">Conheça nossos ambientes.</p>
    </div>

    <div class="amb reveal">
      <div class="amb-media"><Img src="salao.png" alt="Salão principal do Leopoldo House com pé-direito de 7 metros" width={900} style="width:100%;height:100%;object-fit:cover;border-radius:inherit" /></div>
      <div class="amb-text">
        <span class="amb-num">01</span>
        <h3 class="h3">Salão amplo com 7m de pé direito</h3>
        <p>Impacto visual e sensação de amplitude que impressionam logo na chegada, perfeito para cenografias imersivas, ativações de marca ou montagens especiais.</p>
      </div>
    </div>

    <div class="amb reveal">
      <div class="amb-media"><Img src="mezanino.jpg" alt="Mezanino do Leopoldo House — lounge executivo" width={900} style="width:100%;height:100%;object-fit:cover;border-radius:inherit" /></div>
      <div class="amb-text">
        <span class="amb-num">02</span>
        <h3 class="h3">Mezanino</h3>
        <p>Espaço exclusivo com banheiro privativo, ideal para sala de apoio, reuniões paralelas ou uso executivo durante o evento.</p>
      </div>
    </div>

    <div class="amb reveal">
      <div class="amb-media"><Img src="rooftop.jpg" alt="Rooftop Garden do Leopoldo House com teto de vidro" width={900} style="width:100%;height:100%;object-fit:cover;border-radius:inherit" /></div>
      <div class="amb-text">
        <span class="amb-num">03</span>
        <h3 class="h3">Rooftop Garden</h3>
        <p>Com teto de vidro e atmosfera de ar livre, é o cenário ideal para eventos diurnos, brunchs corporativos ou sessões de integração ao pôr do sol.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════════════ GASTRONOMIA ════════════ -->
<section class="gastro" id="gastronomia">
  <Img src="gastronomia.png" alt="Mesa de gastronomia do Leopoldo House — buffet premium" width={1920} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;opacity:.55" />
  <div class="gastro-veil"></div>
  <div class="wrap">
    <div class="gastro-inner reveal">
      <span class="eyebrow center light">Gastronomia</span>
      <h2 class="h2">Mais do que um buffet. Uma experiência gastronômica.</h2>
      <p class="lede">Um cardápio desenvolvido para acompanhar o propósito do seu evento corporativo, com execução precisa e apresentação refinada.</p>
    </div>
  </div>
</section>

<!-- ════════════ PROVA SOCIAL ════════════ -->
<section class="proof">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow center">Confiança</span>
      <h2 class="h2">Empresas que confiaram em nosso espaço de eventos.</h2>
      <p class="lede">Conheça o Leopoldo House e viva uma experiência de sucesso.</p>
    </div>
    <div class="logos reveal">
      <div class="logobox">Logo 01</div>
      <div class="logobox">Logo 02</div>
      <div class="logobox">Logo 03</div>
      <div class="logobox">Logo 04</div>
      <div class="logobox">Logo 05</div>
      <div class="logobox">Logo 06</div>
      <div class="logobox">Logo 07</div>
      <div class="logobox">Logo 08</div>
      <div class="logobox">Logo 09</div>
    </div>
  </div>
</section>

<!-- ════════════ CONTATO ════════════ -->
<section class="contact" id="contato">
  <div class="wrap">
    <div class="section-head light reveal">
      <span class="eyebrow center light">Contato</span>
      <h2 class="h2">Vamos começar a planejar seu evento corporativo?</h2>
      <p class="lede">Preencha o formulário para receber nosso contato.</p>
    </div>

    <div class="form reveal">
      <LeadForm
        formId="lead-form"
        project={config.project_slug}
        submitUrl={config.forms['lead-form'].webhooks[0]}
        redirectUrl={config.forms['lead-form'].redirect_on_success}
        submitText="Enviar solicitação →"
        honeypot
        successTitle="Solicitação enviada!"
        successText="Obrigado. Em breve entraremos em contato."
        fields={[
          { name: 'nome',     type: 'text',     placeholder: 'Seu nome completo',  required: true,  full: true, autocomplete: 'name' },
          { type: 'row', fields: [
            { name: 'telefone', type: 'tel',    placeholder: '(11) 90000-0000',    required: true,  mask: 'phone', autocomplete: 'tel' },
            { name: 'email',    type: 'email',  placeholder: 'seu@email.com',      required: true,  autocomplete: 'email' },
          ]},
          { type: 'row', fields: [
            { name: 'data',     type: 'date',   placeholder: 'Data do evento',     required: false },
            { name: 'pessoas',  type: 'number', placeholder: 'Nº de convidados',   required: false, min: '1' },
          ]},
          { name: 'tipo', type: 'select', full: true, required: false, options: [
            { value: '', label: 'Tipo de evento', disabled: true, selected: true },
            { value: 'Coquetel',          label: 'Coquetel' },
            { value: 'Jantar',            label: 'Jantar' },
            { value: 'Plenária',          label: 'Plenária' },
            { value: 'Workshop',          label: 'Workshop' },
            { value: 'Convenção',         label: 'Convenção' },
            { value: 'Treinamento',       label: 'Treinamento' },
            { value: 'Confraternização',  label: 'Confraternização' },
            { value: 'Outro',             label: 'Outro' },
          ]},
          { name: 'detalhes', type: 'textarea', placeholder: 'Conte um pouco sobre o que você imagina para o evento.', required: false, full: true, rows: 4 },
        ]}
      />
    </div>
  </div>
</section>

<!-- ════════════ RODAPÉ ════════════ -->
<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-logo"><Img src="logo-leopoldo.png" alt="Leopoldo House" width={200} /></div>
      <div class="foot-links">
        <div class="foot-col">
          <a href="#sobre">O Espaço</a>
          <a href="#eventos">Eventos</a>
          <a href="#estrutura">Estrutura</a>
        </div>
        <div class="foot-col">
          <a href="#gastronomia">Gastronomia</a>
          <a href="#contato">Solicitar orçamento</a>
          <a href="https://www.instagram.com/villagustocidadejardim/" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>Copyright © 2026 Leopoldo House - Todos os direitos reservados</span>
      <span class="foot-dev">Desenvolvido por <a href="https://dmove.com.br" target="_blank" rel="noopener"><Img src="logo-dmove.avif" alt="Dmove" width={72} /></a></span>
    </div>
  </div>
</footer>


</Base>
<script>
  import '../scripts/index.js';
</script>
<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(carousel => {
    const wrap       = carousel.querySelector<HTMLElement>('.about-track-wrap')!;
    const track      = carousel.querySelector<HTMLElement>('.about-track')!;
    const slides     = Array.from(carousel.querySelectorAll<HTMLElement>('.about-slide'));
    const dotsEl     = carousel.querySelector<HTMLElement>('[data-dots]')!;
    const GAP        = parseInt(getComputedStyle(track).gap) || 18;
    const total      = slides.length;
    let visible      = window.innerWidth <= 760 ? 1 : 3;
    let maxIdx       = total - visible;
    let current      = 0;
    let timer: ReturnType<typeof setInterval>;

    function slideWidth() {
      return (wrap.offsetWidth - GAP * (visible - 1)) / visible;
    }

    function resize() {
      visible = window.innerWidth <= 760 ? 1 : 3;
      maxIdx  = total - visible;
      if (current > maxIdx) current = maxIdx;
      const w = slideWidth();
      slides.forEach(s => (s.style.width = w + 'px'));
      render(false);
    }

    function render(animate = true) {
      track.style.transition = animate ? 'transform .55s var(--ease)' : 'none';
      track.style.transform  = `translateX(-${current * (slideWidth() + GAP)}px)`;
      // stagger: slot do meio (current + 1) desce
      slides.forEach((s, i) => s.classList.toggle('is-middle', i === current + 1));
      dotsEl.querySelectorAll('.carousel-dot').forEach((d, i) =>
        d.classList.toggle('is-active', i === current)
      );
    }

    function goTo(n: number) {
      current = Math.max(0, Math.min(n, maxIdx));
      render();
    }

    // build dots (one per stop position)
    function buildDots() {
      dotsEl.innerHTML = '';
      for (let i = 0; i <= maxIdx; i++) {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === 0 ? ' is-active' : '');
        dot.setAttribute('aria-label', `Slide ${i + 1}`);
        dot.addEventListener('click', () => { goTo(i); startTimer(); });
        dotsEl.appendChild(dot);
      }
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current < maxIdx ? current + 1 : 0), 4500);
    }

    carousel.querySelector('.carousel-prev')?.addEventListener('click', () => {
      goTo(current > 0 ? current - 1 : maxIdx); startTimer();
    });
    carousel.querySelector('.carousel-next')?.addEventListener('click', () => {
      goTo(current < maxIdx ? current + 1 : 0); startTimer();
    });

    window.addEventListener('resize', () => { resize(); buildDots(); });

    resize();
    buildDots();
    startTimer();
  });
</script>
